(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test-compiles "get: numeric index"
  "(get arr 0)" "arr[0];")

(test-compiles "get: string key"
  "(get obj \"name\")" "obj[\"name\"];")

(test-compiles "get: variable key"
  "(get obj key)" "obj[key];")

(test-compiles "get: nested"
  "(get (get matrix 0) 1)" "matrix[0][1];")

(test-compiles "get: expression as key"
  "(get args (- len 1))" "args[len - 1];")

(test "get: wrong arity throws"
  (is-thrown (compile "(get obj)") Error))
