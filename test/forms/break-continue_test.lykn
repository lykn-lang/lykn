(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test-compiles "break: no label"
  "(break)" "break;")

(test-compiles "break: with label"
  "(break my-loop)" "break myLoop;")

(test-compiles "continue: no label"
  "(continue)" "continue;")

(test-compiles "continue: with label"
  "(continue my-loop)" "continue myLoop;")
