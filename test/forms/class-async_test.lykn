(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test "class async: async method"
  (bind result (compile "(class C () (async (fetch-data () (return (await (get-it))))))"))
  (includes result "async")
  (includes result "fetchData"))

(test "class async: static async"
  (bind result (compile "(class C () (static (async (load () (return 1)))))"))
  (includes result "static")
  (includes result "async"))

(test "class async: async private method"
  (bind result (compile "(class C () (async (-do-work () (return 1))))"))
  (includes result "async")
  (includes result "#_doWork"))
