(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test "class: basic no extends"
  (bind result (compile "(class Foo () (constructor () (return)))"))
  (includes result "class Foo")
  (includes result "constructor"))

(test "class: with extends"
  (bind result (compile "(class Dog (Animal) (constructor (name) (super name)))"))
  (includes result "extends Animal")
  (includes result "super(name)"))

(test "class: empty body"
  (bind result (compile "(class Empty ())"))
  (includes result "class Empty"))

(test "class: method with this"
  (bind result (compile "(class Greeter () (greet () (return this:name)))"))
  (includes result "this.name"))
