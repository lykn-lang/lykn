(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test "for-in: basic"
  (bind result (compile "(for-in key obj (console:log key))"))
  (includes result "for (const key in obj)"))

(test "for-in: missing args throws"
  (is-thrown (compile "(for-in key)") Error))
