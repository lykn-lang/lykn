(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test-compiles "seq: two expressions"
  "(seq a b)" "(a, b);")

(test-compiles "seq: three expressions"
  "(seq a b c)" "(a, b, c);")

(test "seq: too few args throws"
  (is-thrown (compile "(seq a)") Error))
