(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test-compiles "+=: basic"
  "(+= x 1)" "x += 1;")

(test-compiles "-=: basic"
  "(-= x 1)" "x -= 1;")

(test-compiles "*=: basic"
  "(*= x 2)" "x *= 2;")

(test-compiles "**=: exponentiation assignment"
  "(**= x 2)" "x **= 2;")

(test-compiles "&&=: logical and assignment"
  "(&&= x y)" "x &&= y;")

(test-compiles "||=: logical or assignment"
  "(||= x y)" "x ||= y;")

(test-compiles "??=: nullish coalescing assignment"
  "(??= x y)" "x ??= y;")

(test "+=: wrong arity throws"
  (is-thrown (compile "(+= x)") Error))
