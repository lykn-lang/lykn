(import-macros "testing"
  (test test-compiles is-equal is-thrown includes))
(import "testing/helpers.js" ((alias compile-kernel compile)))

(test "do-while: basic"
  (bind result (compile "(do-while (> x 0) (-= x 1))"))
  (includes result "do")
  (includes result "while")
  (includes result "x > 0"))

(test "do-while: missing body throws"
  (is-thrown (compile "(do-while true)") Error))
