(import-macros "testing" (test is-equal))
(import "testing/helpers.js" (compile-all))

(test "macro params: rest captures remaining"
  (bind result (compile-all "
    (macro when (test (rest body))
      `(if ,test (block ,@body)))
    (when true (console:log \"a\") (console:log \"b\"))
  "))
  (is-equal (result:includes "a") true)
  (is-equal (result:includes "b") true))

(test "macro params: single param"
  (bind result (compile-all "
    (macro not-null (x) `(!== ,x null))
    (not-null y)
  "))
  (is-equal (result:includes "!==") true)
  (is-equal (result:includes "null") true))

(test "macro params: skip with unused param"
  (bind result (compile-all "
    (macro second (unused x) x)
    (second foo bar)
  "))
  (is-equal result "bar;"))
