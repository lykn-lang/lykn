(import-macros "testing" (test is-equal))
(import "testing/helpers.js" (compile-all))

(test "gensym function: available in macro body"
  (bind result (compile-all "
    (macro with-temp (val (rest body))
      (const tmp ($gensym \"tmp\"))
      `(block (let ,tmp ,val) ,@body))
    (with-temp 42 (console:log \"done\"))
  "))
  (is-equal (result:includes "tmp__gensym") true))

(test "gensym function: default prefix"
  (bind result (compile-all "
    (macro with-gen (val)
      (const tmp ($gensym))
      `(let ,tmp ,val))
    (with-gen 99)
  "))
  (is-equal (result:includes "g__gensym") true))
